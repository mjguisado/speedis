{
    "name": "speedis",
    "version": "2.0.2",
    "description": "An HTTP cache based on Redis",
    "main": "An HTTP cache based on Redis",
    "type": "module",
    "scripts": {
        "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon src/index.js",
        "debug": "NODE_TLS_REJECT_UNAUTHORIZED=0 node --inspect src/index.js",
        "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 node --test 'test/**/*.test.js'",
        "start": "node src/index.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mjguisado/speedis.git"
    },
    "author": "Manuel J Guisado Rasco",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/mjguisado/speedis/issues"
    },
    "homepage": "https://github.com/mjguisado/speedis#readme",
    "dependencies": {
        "@xmldom/xmldom": "^0.9.9",
        "fastify": "^5.8.4",
        "jose": "^6.2.2",
        "jsonpath": "^1.3.0",
        "opossum": "^9.0.0",
        "prom-client": "^15.1.3",
        "redis": "^5.11.0",
        "sax": "^1.6.0",
        "xpath": "^0.0.34"
    },
    "devDependencies": {
        "@fastify/caching": "^9.0.3",
        "@fastify/etag": "^6.1.0",
        "nodemon": "^3.1.14"
    }
}
