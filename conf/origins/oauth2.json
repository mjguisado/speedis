{
    "id": "mocks",
    "prefix": "/api",
    "logLevel": "warn",
    "exposeErrors": true,
    "origin": {
        "http1xOptions": {
            "host": "mocks",
            "port": 3030,
            "timeout": 1000
        },
        "agentOptions": {
            "keepAlive": true
        },  
        "originTimeout": 1000,
        "originBreaker": true,
        "originBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 2000
        }
    },
    "redis": {
        "redisOptions": {
            "url": "redis://redis:6379"
        },
        "redisTimeout": 500,
        "redisBreaker": false,
        "redisBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 5000
        },
        "disableOriginOnRedisOutage": true
    },
    "oauth2": {
        "id": "mocks.oauth2",
        "logLevel": "warn",
        "baseUrl": "https://mocks.localhost",
        "clientId": "speedis-client",
        "clientSecret": "MqSjdYcZPkoamoTZi8viqzmpGdxp3pOw",
        "discoverySupported": true,
        "authorizationServerMetadataLocation": "https://keycloak:8443/realms/speedis/.well-known/oauth-authorization-server",
        "authorizationServerMetadata": {
            "issuer": "https://keycloak.localhost:8443/realms/speedis",
            "authorization_endpoint": "https://keycloak.localhost:8443/realms/speedis/protocol/openid-connect/auth",
            "token_endpoint": "https://keycloak:8443/realms/speedis/protocol/openid-connect/token",
            "revocation_endpoint": "https://keycloak:8443/realms/speedis/protocol/openid-connect/revoke",
            "jwks_uri": "https://keycloak:8443/realms/speedis/protocol/openid-connect/certs",
            "end_session_endpoint" : "https://keycloak.localhost:8443/realms/speedis/protocol/openid-connect/logout"
        },
        "authorizationRequest": {
            "redirect_uri": "https://mocks.localhost/oauth2/callback",
            "scope": "openid profile email"
        },
        "pkceEnabled": true,
        "postAuthRedirectUri": "https://mocks.localhost/mocks/items/RealBetis?delay=300&cc=public,max-age=10&a=alfa&b=beta&c=",
        "logoutRequest": {
            "post_logout_redirect_uri": "https://mocks.localhost/mocks/users/1"
       },
       "authStrategies": [
            {
                "urlPatterns": [
                    "/mocks/items/public-.*",
                    "/mocks/health",
                    "/mocks/version"
                ],
                "grantType": "none"
            },
            {
                "urlPatterns": [
                    "/mocks/api/internal/.*",
                    "/mocks/webhooks/.*"
                ],
                "grantType": "client_credentials",
                "scope": "basic"
            },
            {
                "urlPatterns": [
                    "/mocks/users/.*",
                    "/mocks/profile/.*"
                ],
                "grantType": "authorization_code",
                "authorizationRequest": {
                    "redirect_uri": "https://mocks.localhost/oauth2/callback",
                    "scope": "openid profile email"
                },
                "pkceEnabled": true,
                "postAuthRedirectUri": "https://mocks.localhost/mocks/items/RealBetis?delay=300&cc=public,max-age=10&a=alfa&b=beta&c=",
                "logoutRequest": {
                    "post_logout_redirect_uri": "https://mocks.localhost/mocks/users/1"
                }
            }
        ]
    }
}