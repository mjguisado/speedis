{
    "id": "oauth",
    "prefix": "/oauth",
    "logLevel": "debug",
    "exposeErrors": true,
    "origin": {
        "http2Options": {
            "authority": "https://mocks:3030",
            "options": {
                "rejectUnauthorized": false,
                "timeout": 1000
            }
        },
        "originTimeout": 1000,
        "originBreaker": true,
        "originBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 2000
        },
        "authentication": {
            "scheme": "Bearer",
            "realm": "mocks api",
            "bearer": {
                "jwksUri": "https://keycloak:8443/realms/speedis/protocol/openid-connect/certs"
            },
            "idTransformation": {
                "hash": {
                    "enabled": true,
                    "algorithm": "sha256",
                    "hex": true
                }
            }
        }
    },
    "cache": {
        "cacheables": [
            {
                "urlPattern": "/mocks/public/.*",
                "ttl": 20
            },
            {
                "urlPattern": "/mocks/restricted/.*"
            },
            {
                "urlPattern": "/mocks/private/.*",
                "private": true
            }
        ],
        "ignoredQueryParams": [
            "cc",
            "delay"
        ],
        "localRequestsCoalescing": true,
        "distributedRequestsCoalescing": true,
        "distributedRequestsCoalescingOptions": {
            "lockTTL": 750,
            "retryCount": 3,
            "retryDelay": 500,
            "retryJitter": 250
        }
    },
    "oauth2": {
        "id": "mocks.oauth2",
        "logLevel": "warn",
        "baseUrl": "https://oauth.localhost",
        "clientId": "speedis-oauth-client",
        "clientSecret": "xSCVPujSA8962iIoaDFrmybIDkLcPC5a",
        "discoverySupported": true,
        "authorizationServerMetadataLocation": "https://keycloak:8443/realms/speedis/.well-known/oauth-authorization-server",
        "authorizationServerMetadata": {
            "issuer": "https://keycloak.localhost:8443/realms/speedis",
            "authorization_endpoint": "https://keycloak.localhost:8443/realms/speedis/protocol/openid-connect/auth",
            "token_endpoint": "https://keycloak:8443/realms/speedis/protocol/openid-connect/token",
            "revocation_endpoint": "https://keycloak:8443/realms/speedis/protocol/openid-connect/revoke",
            "jwks_uri": "https://keycloak:8443/realms/speedis/protocol/openid-connect/certs",
            "end_session_endpoint" : "https://keycloak.localhost:8443/realms/speedis/protocol/openid-connect/logout"
        },
        "authorizationRequestParameters": {
            "redirect_uri": "https://oauth.localhost/oauth2/callback",
            "scope": "restricted private"
        },
        "pkceEnabled": true,
        "postAuthRedirectUri": "https://oauth.localhost/mocks/public/items/RealBetis?delay=300&cc=public,max-age=10",
        "logoutRequest": {
            "post_logout_redirect_uri": "https://oauth.localhost/mocks/public/users/1"
       },
       "authStrategies": [
            {
                "urlPatterns": [
                    "/mocks/public/.*"
                ],
                "grantType": "none"
            },
            {
                "urlPatterns": [
                    "/mocks/restricted/.*"
                ],
                "grantType": "client_credentials",
                "parameters": {
                    "scope": "restricted"
                }
            },
            {
                "urlPatterns": [
                    "/mocks/private/.*"
                ],
                "grantType": "authorization_code",
                "parameters": {
                    "scope": "private"
                }
            }
        ]
    },    
    "redis": {
        "redisOptions": {
            "url": "redis://redis:6379"
        },
        "redisTimeout": 500,
        "redisBreaker": false,
        "redisBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 5000
        },
        "disableOriginOnRedisOutage": true
    }
}
