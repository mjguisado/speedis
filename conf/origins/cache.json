{
    "id": "cache",
    "prefix": "/cache",
    "logLevel": "warn",
    "exposeErrors": true,
    "origin": {
        "http2Options": {
            "authority": "https://mocks:3030",
            "options": {
                "rejectUnauthorized": false,
                "timeout": 1000
            }
        },
        "originTimeout": 1000,
        "originBreaker": true,
        "originBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 2000
        },
        "authentication": {
            "scheme": "Bearer",
            "realm": "mocks_api",
            "bearer": {
                "allowUnsigned": false,
                "verifyJwtSignature": false
            },
            "idTransformation": {
                "hash": {
                    "enabled": true,
                    "algorithm": "sha256",
                    "hex": true
                }
            }
        }
    },
    "redis": {
        "redisOptions": {
            "url": "redis://redis:6379"
        },
        "redisTimeout": 500,
        "redisBreaker": false,
        "redisBreakerOptions": {
            "errorThresholdPercentage": 25,
            "resetTimeout": 5000
        },
        "disableOriginOnRedisOutage": true
    },
    "cache": {
        "defaultCacheSettings": {
            "methods": [ "GET", "HEAD"],
            "private": false,
            "ttl": 3600,
            "sortQueryParams": true,
            "ignoredQueryParams": [
                "cc",
                "delay",
                "vary"
            ]
        },
        "cacheables": [
            {
                "urlPattern": "/mocks/public/items/.*",
                "cacheSettings": {
                    "ttl": 20
                }
            },
            {
                "urlPattern": "/mocks/public/status/.*"
            },
            {
                "urlPattern": "/mocks/public/soap/*",
                "cacheSettings": {
                    "methods": [ "POST" ]
                }
            },
            {
                "urlPattern": "/mocks/private/.*",
                "cacheSettings": {
                    "private": true
                }
            }
        ],
        "localRequestsCoalescing": true,
        "distributedRequestsCoalescing": true,
        "distributedRequestsCoalescingOptions": {
            "lockTTL": 750,
            "retryCount": 3,
            "retryDelay": 500,
            "retryJitter": 250
        }
    },
    "bff": {
        "transformations": [
            {
                "urlPattern": "/mocks/public/items/.*",
                "actions": [
                    {
                        "phase": "OriginResponse",
                        "uses": "headers:setCacheControlByStatusCode",
                        "with": {
                            "statusCodeRules": {
                                "404": "public, max-age=300",
                                "403": "no-store",
                                "5xx": "no-cache"
                            }
                        }
                    }
                ]
            },
            {
                "urlPattern": ".*",
                "actions": [
                    {
                        "phase": "OriginResponse",
                        "uses": "headers:setHeaders",
                        "with": {
                            "X-Powered-By": "Speedis"
                        }
                    }
                ]
            },
            {
                "urlPattern": "/mocks/public/users/1",
                "actions": [
                    {
                        "phase": "OriginResponse",
                        "uses": "json:deleteJsonPaths",
                        "with": {
                            "jsonpaths": [
                                "$[*].user.phones[*].type",
                                "$[*].metadata"
                            ]
                        }
                    }
                ]
            },
            {
                "urlPattern": "/mocks/public/users/2",
                "actions": [
                    {
                        "phase": "VariantsTracker",
                        "uses": "json:keepJsonPaths",
                        "with": {
                            "jsonpaths": [
                                "$[*].user.phones[*].type",
                                "$[*].metadata"
                            ]
                        }
                    }
                ]
            },
            {
                "urlPattern": "/mocks/public/soap/sax",
                "actions": [
                    {
                        "phase": "CacheKeyGeneration",
                        "uses": "xmlsax:xmlBodyFingerprint",
                        "with": {
                            "elements": ["ns:category", "ns:id"],
                            "algorithm": "md5",
                            "encoding": "hex"
                        }
                    }
                ]
            },
            {
                "urlPattern": "/mocks/public/soap/xpath",
                "actions": [
                    {
                        "phase": "CacheKeyGeneration",
                        "uses": "xmlxpath:xpathBodyFingerprint",
                        "with": {
                            "xpaths": [
                                "//ns:product/ns:category | //ns:product/ns:id"
                            ],
                            "namespaces": {
                                "soap": "http://schemas.xmlsoap.org/soap/envelope/",
                                "ns": "http://example.com/products"
                            },
                            "algorithm": "md5",
                            "encoding": "hex"
                        }
                    }
                ]
            }
        ]
    },
    "variantsTracker": {
        "urlPatterns": [
            "/mocks/public/users/*"
        ]
    }
}