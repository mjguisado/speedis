              "type": "boolean",
              "default": false
            },
            "buildPrettyMeta": {
              "type": "object"
            },
            "caseSensitive": {
              "type": "boolean",
              "default": true
            },
            "constraints": {
              "type": "object"
            },
            "ignoreDuplicateSlashes": {
              "type": "boolean",
              "default": false
